{
  // ============================================
  // 编辑器基础设置
  // ============================================
  "editor.fontSize": 14, // 编辑器字体大小
  "editor.fontFamily": "Monaco, 'Courier New', monospace", // 编辑器字体
  "editor.lineHeight": 1.6, // 行高，1.6 倍行距更舒适
  "editor.tabSize": 2, // Tab 键缩进空格数
  "editor.insertSpaces": true, // 按 Tab 键时插入空格而不是制表符
  "editor.wordWrap": "on", // 自动换行，避免横向滚动
  "editor.minimap.enabled": true, // 显示代码缩略图（右侧小地图）
  "editor.formatOnSave": true, // 保存文件时自动格式化代码
  // ============================================
  // 文件和工作区
  // ============================================
  "files.autoSave": "afterDelay", // 延迟自动保存文件
  "files.autoSaveDelay": 1000, // 自动保存延迟时间（毫秒），1秒后保存
  "files.exclude": {
    // 在文件浏览器中隐藏这些文件/文件夹
    "**/.git": true, // 隐藏 Git 目录
    "**/.DS_Store": true, // 隐藏 macOS 系统文件
    "**/node_modules": true, // 隐藏 Node.js 依赖目录
    "**/__pycache__": true // 隐藏 Python 缓存目录
  },
  // ============================================
  // 终端设置
  // ============================================
  "terminal.integrated.fontSize": 13, // 终端字体大小
  "terminal.integrated.fontFamily": "Menlo, Monaco, 'Courier New', monospace", // 终端字体
  // ============================================
  // Git 设置
  // ============================================
  "git.autofetch": true, // 自动从远程仓库获取更新
  "git.confirmSync": false, // 同步时不显示确认对话框
  "git.enableSmartCommit": true, // 启用智能提交（没有暂存文件时提交所有更改）
  // ============================================
  // 工作区和界面设置
  // ============================================
  "workbench.startupEditor": "none", // 启动时不打开欢迎页面
  "explorer.confirmDelete": false, // 删除文件时不显示确认对话框
  "explorer.confirmDragAndDrop": false, // 拖放文件时不显示确认对话框
  // ============================================
  // 扩展特定设置
  // ============================================
  "extensions.experimental.affinity": {
    // VSCode Neovim 扩展使用独立进程，提高性能
    "asvetliakov.vscode-neovim": 1
  },
  // ============================================
  // VSCode Neovim 设置（修复中文渲染问题）
  // ============================================
  "vscode-neovim.neovimInitVimPaths.darwin": "~/.config/nvim/init.lua", // macOS 上的 Neovim 配置文件路径
  "vscode-neovim.useWSL": false, // 不使用 WSL
  "vscode-neovim.textDecorations.enable": false, // 禁用 Neovim 的文本装饰，避免渲染冲突
  // "vscode-neovim.compositeKeys": {
  //   // 组合键配置：jk 快速退出插入模式
  //   "jk": {
  //     "command": "vscode-neovim.escape"
  //   }
  // },
  // ============================================
  // Neovim 键位映射（VSCode 中按 j/k 以“换行显示”为单位移动）
  // 说明：这里仅在 VSCode 中生效，不会改变终端 Neovim 的行为
  //
  // 注意：这里配置其实是生效的，但是因为neovim与vscode的换行不同，neovim无法感知vscode的换行，所以无法实现按照显示行移动，这里的配置无效，改为使用VsCode自己的光标移动。见 keybindings.json 中的"VSCode 中 Neovim 模式下按“显示行”移动 j/k"配置。
  // ============================================
  "vscode-neovim.normalModeKeyBindings": [
    {
      "before": ["j"],
      "after": ["g", "j"]
    },
    {
      "before": ["k"],
      "after": ["g", "k"]
    }
  ],
  "vscode-neovim.visualModeKeyBindings": [
    {
      "before": ["j"],
      "after": ["g", "j"]
    },
    {
      "before": ["k"],
      "after": ["g", "k"]
    }
  ],
  "editor.formatOnSaveMode": "modifications", // 仅格式化修改过的代码
  "javascript.format.enable": false, // AI 助手自动模式
  // ============================================
  // 光标设置（配合 Neovim 使用）
  // ============================================
  "editor.cursorBlinking": "solid", // 光标不闪烁，避免与 Neovim 冲突
  "editor.cursorSmoothCaretAnimation": "off", // 关闭光标平滑动画
  // ============================================
  // Go 语言特定设置
  // ============================================
  "[go]": {
    "editor.insertSpaces": false, // Go 官方推荐使用 Tab 字符而不是空格
    "editor.tabSize": 4, // Tab 显示为 4 个空格宽度
    "editor.formatOnSave": true, // 保存时自动格式化
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit" // 保存时自动整理 import
    }
  },
  "[go.mod]": {
    "editor.insertSpaces": false,
    "editor.tabSize": 4,
    "editor.formatOnSave": true
  },
  "[go.sum]": {
    "editor.insertSpaces": false,
    "editor.tabSize": 4
  },
  // ============================================
  // Python 语言特定设置
  // ============================================
  "[python]": {
    "editor.insertSpaces": true, // Python 使用空格（PEP 8 标准）
    "editor.tabSize": 4, // 4 个空格缩进
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "charliermarsh.ruff", // 使用 Black 格式化（需安装扩展）
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  // ============================================
  // Java 语言特定设置
  // ============================================
  "[java]": {
    "editor.insertSpaces": true, // Java 使用空格
    "editor.tabSize": 4, // 4 个空格缩进（Java 标准）
    "editor.formatOnSave": true
  },
  // ============================================
  // Rust 语言特定设置
  // ============================================
  "[rust]": {
    "editor.insertSpaces": true, // Rust 使用空格
    "editor.tabSize": 4, // 4 个空格缩进（rustfmt 默认）
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  // ============================================
  // JavaScript/TypeScript 语言特定设置
  // ============================================
  "[javascript]": {
    "editor.insertSpaces": true, // 使用空格
    "editor.tabSize": 2, // 2 个空格缩进（社区主流）
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode" // 使用 Prettier
  },
  "[javascriptreact]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2, // 2 个空格缩进
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // ============================================
  // Lua 语言特定设置
  // ============================================
  "[lua]": {
    "editor.insertSpaces": true, // Lua 使用空格
    "editor.tabSize": 2, // 2 个空格缩进（社区主流）
    "editor.formatOnSave": true
  },
  // ============================================
  // HTML/CSS/SCSS 设置
  // ============================================
  "[html]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "[css]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[scss]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  // ============================================
  // Markdown 设置
  // ============================================
  "[markdown]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.wordWrap": "on",
    "editor.formatOnSave": true, // 启用保存时格式化
    "editor.defaultFormatter": "esbenp.prettier-vscode", // 使用 Prettier 格式化
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  // ============================================
  // YAML 设置
  // ============================================
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2, // YAML 必须使用空格，通常 2 个
    "editor.formatOnSave": true
  },
  // ============================================
  // Shell 脚本设置
  // ============================================
  "[shellscript]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2, // Shell 脚本通常使用 2 个空格
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "foxundermoon.shell-format" // 使用 shell-format 扩展
  },
  // Shell-format 扩展配置
  "shellformat.flag": "-i 2 -ci", // -i 2: 缩进2个空格, -ci: case 语句缩进
  // ============================================
  // Multi-command 扩展配置
  // ============================================
  // 需要安装扩展: ryuta46.multi-command
  // 用于创建自定义命令，执行多个 VSCode 命令序列
  "multiCommand.commands": [
    {
      // 自定义命令：隐藏所有面板
      "command": "multiCommand.hideAllPanels",
      "sequence": [
        "workbench.action.closeSidebar", // 关闭左侧边栏
        "workbench.action.closePanel", // 关闭底部面板
        "workbench.action.closeAuxiliaryBar" // 关闭右侧辅助栏
      ]
    },
    {
      // 自定义命令：显示所有面板
      "command": "multiCommand.showAllPanels",
      "sequence": [
        "workbench.action.toggleSidebarVisibility", // 切换左侧边栏
        "workbench.action.togglePanel", // 切换底部面板
        "workbench.action.toggleAuxiliaryBar" // 切换右侧辅助栏
      ]
    }
  ],
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar"
  },
  "app": {
    "configGeneralDisplayLanguage": "zh-cn",
    "configGeneralAiResponseLanguage": "zh-cn",
    "configGeneralImprovementPlan": "agree",
    "configGeneralImportSettings": "VS Code",
    "configCompletionEnableNES": true,
    "configCompletionDisabledLanguages": [],
    "configCompletionTriggerInComment": true,
    "configCompletionAutoImport": true,
    "configChatWebToolsMode": "Ask every time",
    "configChatAskModeUseTools": true,
    "configChatEditFileTool": false,
    "configChatTerminalRunMode": "askEveryTime",
    "configChatCommandDenyList": "rm,mv,sudo,wget,curl,chown",
    "configChatCommandAllowlist": "",
    "configChatAutoRunMcpTools": true,
    "configChatMethodQuickOperation": false,
    "configChatShowSelectionToolbar": true,
    "configQuestDefaultLayout": false,
    "configMemoryAutoGenerate": true,
    "configIntegrationsBrowserRunMode": "Ask every time",
    "configIntegrationsBrowserToolsRunMode": "Auto-run",
    "configIntegrationsPlanModeRunConfig": "Ask every time",
    "configAdvancedAutoUpdate": true,
    "configAdvancedProxyMode": "system",
    "configAdvancedProxyURL": ""
  },
  "git.openRepositoryInParentFolders": "never",
  "editor.mouseWheelZoom": true,
  "makefile.configureOnOpen": false,
  "redhat.telemetry.enabled": false
  // 在这里添加你的其他设置
}
