**/agent-core/skills/docx/
**/agent-core/skills/pdf/
**/agent-core/skills/pptx/
**/agent-core/skills/xlsx/
**/agent-core/skills/mcp-tools/
**/agent-core/skills/self-improvement/
**/agent-core/skills/skill-creator/
**/agent-core/skills/skill-finder/

# Agent-level skills dir (soft-links managed by platform)
**/agents/*/skills/
**/agents/*/tools/

# Channels: contains user IDs, openIDs, bot token prefixes in filenames — ignore entirely
**/channels/
