# .gitconfig.local 示例文件
# 这个文件用于存放本地特定的 Git 配置（不提交到 Git）
# 复制此文件为 .gitconfig.local 并根据需要修改

# ============================================
# 本地用户信息覆盖（如果需要）
# ============================================
# [user]
# 	name = Your Name
# 	email = your.email@example.com

# ============================================
# 本地特定配置
# ============================================
# [core]
# 	sshCommand = ssh -i ~/.ssh/id_rsa_custom

# ============================================
# 代理配置（如果需要）
# ============================================
# [http]
# 	proxy = http://127.0.0.1:7890
# [https]
# 	proxy = http://127.0.0.1:7890
