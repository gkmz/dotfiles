# Git 全局配置
# 使用 includeIf 为不同目录设置不同的用户信息

# ============================================
# 用户信息（默认）
# ============================================
[user]
	name = hankmo
	email = hankmo.x@gmail.com

# ============================================
# 核心配置
# ============================================
[core]
	editor = nvim
	autocrlf = input
	excludesfile = ~/.gitignore
	quotepath = false

# ============================================
# 颜色配置
# ============================================
[color]
	ui = auto
	branch = auto
	diff = auto
	status = auto

[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold

[color "status"]
	added = yellow
	changed = green
	untracked = cyan

# ============================================
# 别名
# ============================================
[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	df = diff
	lg = log --color --oneline --graph --decorate --all --pretty=format:'%C(red)%h %C(yellow)%ai -%C(green)%d %s %C(green)%cr %C(white)<%an, %C(yellow)%ar>' --abbrev-commit
	last = log -1 HEAD
	unstage = reset HEAD --
	amend = commit --amend
	undo = reset --soft HEAD^

# ============================================
# 推送配置
# ============================================
[push]
	default = simple
	followTags = false

# ============================================
# 拉取配置
# ============================================
[pull]
	rebase = false

# ============================================
# 分支配置
# ============================================
[branch]
	autosetupmerge = true

# ============================================
# 差异工具
# ============================================
[diff]
	tool = vimdiff

[difftool]
	prompt = false

# ============================================
# 合并工具
# ============================================
[merge]
	tool = vimdiff
	conflictstyle = diff3

[mergetool]
	prompt = false
	keepBackup = false

# ============================================
# 其他配置
# ============================================
[init]
	defaultBranch = main

[credential]
	helper = osxkeychain

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

# ============================================
# 条件包含（根据目录使用不同配置）
# ============================================
[includeIf "gitdir:~/workspace/opensource/"]
	path = ~/.git_os
[includeIf "gitdir:~/workspace/"]
	path = ~/.git_me
[includeIf "gitdir:~/workspace/.ws/"]
	path = ~/.git_wk
[includeIf "gitdir:~/workspace/mine/blockchain/"]
	path = ~/.git_cc

# ============================================
# 本地配置（不提交到 Git）
# ============================================
[include]
	path = ~/.gitconfig.local
[safe]
	directory = *
[coderabbit]
	machineId = cli/99e0704ff5a64ffab15cffe50dc83d6e
